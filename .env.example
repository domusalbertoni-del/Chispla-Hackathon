# ─── Anthropic ──────────────────────────────────────────────
# Server-only · NEVER prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=

# ─── OpenAI (embeddings only · única excepción no-Claude) ────
OPENAI_API_KEY=

# ─── Supabase ───────────────────────────────────────────────
# Public (RLS enforced)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only
SUPABASE_SERVICE_ROLE_KEY=

# ─── Kapso WhatsApp ─────────────────────────────────────────
# API key from Kapso dashboard · used to send messages back via Meta proxy
KAPSO_API_KEY=

# Phone number ID of the Kapso WhatsApp Business number (the one assigned
# to the project 3940198a-9a4c-4b25-9323-ad327ad95236). Discoverable via
# Kapso UI or `node scripts/list-platform-phone-numbers.mjs` from RevOS.
KAPSO_PHONE_NUMBER_ID=

# Kapso v2 webhook secret · HMAC-SHA256 verification of X-Webhook-Signature
# header. Found in Kapso UI → Webhooks → Secret field.
KAPSO_WEBHOOK_SECRET=

# Meta App Secret · only used if the Kapso webhook variant is "Meta forward"
# (current config uses Kapso v2 with KAPSO_WEBHOOK_SECRET above).
META_APP_SECRET=

# Token for Meta GET verification challenge (when Meta first verifies the
# webhook URL, it sends GET with hub.verify_token=<this>). Pick any string
# and use the same one in Kapso webhook config.
WEBHOOK_VERIFY_TOKEN=
